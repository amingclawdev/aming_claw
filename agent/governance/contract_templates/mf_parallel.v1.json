{
  "schema_version": "mf_contract_template.v1",
  "template_id": "mf_parallel.v1",
  "description": "Template for observer-led manual-fix work split across parallel agents. Observer instantiates this template into backlog chain_trigger_json before delegation.",
  "required_instance_fields": [
    "contract_instance_id",
    "workers",
    "test_scenario_policy",
    "evidence_requirements"
  ],
  "lifecycle_states": [
    "contract_draft",
    "implementation_in_progress",
    "review_ready",
    "waiting_merge",
    "needs_revision",
    "accepted_for_merge",
    "merged",
    "rejected"
  ],
  "route_topology_policy": {
    "schema_version": "route_topology_policy.v1",
    "classification_service_id": "route.prompt_alert_bundle",
    "low_risk": {
      "selected_topology": "lightweight_single_lane",
      "recommended_topology": "single_lane.v1",
      "reason_codes": [
        "small_deterministic"
      ],
      "required_lanes": [
        "single_bounded_worker"
      ]
    },
    "high_risk": {
      "selected_topology": "observer_led_parallel_lanes",
      "recommended_topology": "mf_parallel.v1",
      "reason_codes": [
        "priority_p0",
        "priority_p1",
        "governance_routing_runtime_surface",
        "governance_routing_runtime_terms",
        "cross_module_change",
        "observer_direct_implementation_risk"
      ],
      "required_lanes": [
        "observer_coordinator",
        "bounded_implementation_worker",
        "independent_verification_lane",
        "observer_merge_close_gate"
      ],
      "observer_authorities": [
        "merge",
        "redeploy_governance",
        "graph_reconcile",
        "backlog_close",
        "waiver_approval",
        "merge_queue_mutation"
      ]
    },
    "p0_p1_governance_gate": {
      "requires_independent_verification_before": [
        "workflow.merge",
        "backlog.close"
      ],
      "required_evidence_ids": [
        "independent_verification",
        "independent_verification_lane",
        "independent_verification_evidence"
      ]
    }
  },
  "observer_contract": {
    "mode": "observer_only",
    "observer_direct_code": false,
    "default_state": "contract_draft",
    "role_boundary": {
      "default": "no_direct_implementation_code",
      "applies_to": [
        "governed_nontrivial_code",
        "tests",
        "dashboard_assets",
        "runtime_config",
        "governance_docs"
      ],
      "description": "Observer/judge coordinates intent, topology, dispatch, review, merge, reconcile, and close decisions. Governed nontrivial implementation is performed by bounded worker lanes, not by the same observer."
    },
    "judgment_preflight": {
      "when_judgment_brain_available": true,
      "protocol_registry_preflight": {
        "tool": "protocol_list",
        "required_before": "implementation_planning"
      },
      "topology_precheck": {
        "tool": "judgment_plan_precheck",
        "required_before": "implementation_planning",
        "records": [
          "precheck_run_id",
          "decision",
          "status",
          "recommended_topology",
          "required_lanes",
          "evidence_hash"
        ]
      }
    },
    "responsibilities": [
      "clarify_requirements",
      "check_runtime_graph_backlog",
      "run_protocol_registry_preflight",
      "run_topology_precheck",
      "write_backlog_and_contract",
      "start_agents_when_requested_or_contract_approved",
      "review_merge_candidates"
    ],
    "default_forbidden_actions": [
      "direct_implementation_code",
      "wait_for_agents",
      "merge",
      "push",
      "release_gates",
      "activate_graph_refs",
      "close_backlog",
      "delete_worktrees",
      "mutate_merge_queues"
    ],
    "direct_mutation_exception_policy": {
      "schema_version": "observer_direct_mutation_exception.v1",
      "allowed": true,
      "default": "reject",
      "allowed_only_for": "tiny_deterministic_same_observer_mutation",
      "local_precheck": {
        "function": "agent.governance.mf_subagent_contract.validate_observer_direct_mutation_exception",
        "description": "Run and record this validator before any same-observer direct mutation. It is not valid for governed nontrivial implementation work."
      },
      "requires": [
        "observer_direct_mutation=true",
        "observer_role=observer",
        "tiny_deterministic_scope",
        "explicit_reason",
        "allowed_files",
        "dirty_scope_exact_match",
        "timeline_evidence_before_mutation"
      ],
      "description": "Same-observer direct mutation is rejected unless the exception proves a tiny deterministic scope, an explicit reason, exact allowed files, exact dirty-scope evidence, and timeline evidence recorded before mutation."
    },
    "exception_policy": "Privileged observer transitions such as waiting, merge, close, reconcile, gate release, or merge queue mutation require explicit user intent or documented governance transition evidence. Direct implementation code remains forbidden for governed nontrivial work unless the direct_mutation_exception_policy passes before mutation."
  },
  "worker_contract": {
    "required_fields": [
      "task_id",
      "parent_task_id",
      "worker_role",
      "fence_token",
      "route_identity",
      "selected_topology",
      "recommended_topology",
      "owned_files",
      "target_files",
      "test_files",
      "test_commands",
      "responsibility",
      "required_evidence",
      "review_evidence",
      "graph_queries",
      "self_precheck",
      "gate_alignment",
      "final_output"
    ],
    "worker_prompt_contract": {
      "schema_version": "worker_prompt_contract.v1",
      "bounded_fields_only": [
        "target_files",
        "test_files",
        "acceptance_criteria",
        "route_identity",
        "evidence_required",
        "selected_topology",
        "recommended_topology",
        "required_lanes"
      ],
      "forbidden_context_sources": [
        "observer_only_context",
        "raw_private_memory",
        "hidden_context",
        "unmanifested_prompt_text"
      ],
      "description": "Worker-facing prompts receive bounded files, acceptance criteria, route identity, topology, lane, and evidence requirements only. Observer-only context stays with the observer lane."
    },
    "nontrivial_implementation": {
      "default_topology": "dispatch_to_bounded_worker_lane",
      "required_lane_evidence": [
        "target_files",
        "test_commands",
        "worktree_path",
        "branch",
        "fence_token",
        "owned_files",
        "dirty_scope_check",
        "review_evidence"
      ],
      "description": "Governed nontrivial implementation must be assigned to bounded mf_sub/worker lanes with explicit target files, tests, worktree/fence evidence, and observer review evidence."
    },
    "allowed_terminal_states": [
      "review_ready",
      "waiting_merge",
      "needs_revision",
      "rejected"
    ],
    "runtime_identity": {
      "worker_role": "mf_sub",
      "required_fields": [
        "task_id",
        "parent_task_id",
        "worker_role",
        "fence_token"
      ],
      "description": "Observer must instantiate these values from durable task metadata before delegating work. Subagents must echo them in implementation and verification evidence."
    },
    "worktree_policy": {
      "mode": "isolated_worktree_required",
      "dispatch_default": "non_blocking_after_gate",
      "same_worktree_allowed": false,
      "target_main_worktree_dispatch": "blocked_by_default",
      "local_precheck": {
        "schema_version": "mf_subagent_dispatch_gate.v1",
        "function": "agent.governance.mf_subagent_contract.validate_mf_subagent_dispatch_gate",
        "description": "Observer must run and record this dispatch gate before spawn_agent. Passing evidence proves the local mf_sub worker has an isolated branch/worktree/file fence before non-blocking handoff."
      },
      "required_dispatch_fields": [
        "branch",
        "worktree",
        "base_commit",
        "target_head_commit",
        "merge_queue_id",
        "fence_token",
        "owned_files",
        "dirty_scope_check"
      ],
      "override_policy": {
        "allowed": true,
        "default": "reject",
        "requires": [
          "same_worktree_allowed=true",
          "explicit_operator_reason",
          "dirty_scope_exact_match",
          "observer_timeline_event_before_dispatch"
        ],
        "description": "Dispatch into the target/main worktree is blocked by default. A same-worktree exception must be operator-approved, exact dirty-scope checked, and recorded to timeline before spawn_agent."
      }
    },
    "graph_queries": {
      "audited": true,
      "query_source": "mf_subagent",
      "required_context_fields": [
        "task_id",
        "parent_task_id",
        "worker_role",
        "fence_token"
      ],
      "timeline_trace_requirement": "graph_trace_ids",
      "description": "Any subagent graph lookup must use audited query_source=mf_subagent with task identity and fence context; returned trace ids must be recorded in timeline evidence."
    },
    "self_precheck": {
      "required": true,
      "description": "Observer must include the local self-precheck or gate precheck command/API expected for machine-consumed output, and the subagent must record compact self_check evidence."
    },
    "gate_alignment": {
      "required": true,
      "description": "Observer must align required evidence ids, focused tests, E2E decision, and finish-gate expectations before delegation."
    },
    "final_output": {
      "required": true,
      "stop_states": [
        "review_ready",
        "waiting_merge"
      ],
      "required_fields": [
        "status",
        "branch",
        "worktree",
        "owned_changed_files",
        "tests_run",
        "graph_query_trace_ids",
        "precheck_evidence",
        "generated_assets_policy",
        "risks_open_questions"
      ],
      "description": "Worker must stop with structured review evidence and must not merge, push, mutate merge queues, close backlog, activate graph refs, release gates, or delete worktrees."
    },
    "forbidden_capabilities": [
      "merge",
      "push",
      "activate_graph",
      "activate_graph_refs",
      "release_gates",
      "close_backlog",
      "delete_worktrees",
      "mutate_merge_queues"
    ]
  },
  "merge_review_checklist": [
    {
      "id": "contract_fit",
      "description": "Candidate output satisfies the instantiated worker contract and stops in an allowed review state."
    },
    {
      "id": "diff_scope",
      "description": "Changed files stay within the assigned branch/worktree/file fence and match the owned-file list."
    },
    {
      "id": "test_e2e_evidence",
      "description": "Focused tests and required E2E evidence are present, passing, or explicitly deferred with a follow-up backlog row."
    },
    {
      "id": "docs_test_config_impact",
      "description": "Docs, test, config, fixture, and generated artifact impact is declared and reviewed."
    },
    {
      "id": "generated_assets_policy",
      "description": "Generated assets are either source-of-truth updates, reproducible outputs, or excluded from review with a reason."
    },
    {
      "id": "graph_reconcile_plan",
      "description": "Graph binding, Asset Inbox/Governance Hint needs, and post-merge reconcile/update plan are recorded."
    },
    {
      "id": "commit_trailers",
      "description": "Expected Chain trailers and explicit commit file list are ready before merge."
    },
    {
      "id": "backlog_close_policy",
      "description": "Backlog close is deferred until merge, verification, reconcile/update, and close-ready evidence are complete."
    }
  ],
  "service_routes": [
    {
      "route_id": "service.test_governance.preview",
      "service_id": "test_governance.preview",
      "mode": "preview",
      "side_effect_class": "read",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.review.recommendations",
      "service_id": "review.recommendations",
      "mode": "preview",
      "side_effect_class": "read",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.gate.close",
      "service_id": "gate.close",
      "mode": "gate",
      "side_effect_class": "gate",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.cleanup.preview",
      "service_id": "cleanup.preview",
      "mode": "preview",
      "side_effect_class": "read",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.cleanup.apply",
      "service_id": "cleanup.apply",
      "mode": "apply",
      "side_effect_class": "write",
      "required_permissions": [
        "cleanup.apply"
      ],
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    }
  ],
  "event_routes": [
    {
      "route_id": "event.task_completed.test_preview",
      "event_kind": "task.completed",
      "service_route_id": "service.test_governance.preview",
      "enabled": true
    },
    {
      "route_id": "event.task_completed.review_recommendations",
      "event_kind": "task.completed",
      "service_route_id": "service.review.recommendations",
      "enabled": true
    },
    {
      "route_id": "event.backlog_close.gate",
      "event_kind": "backlog.close.requested",
      "service_route_id": "service.gate.close",
      "enabled": true
    },
    {
      "route_id": "event.cleanup.preview",
      "event_kind": "cleanup.requested",
      "service_route_id": "service.cleanup.preview",
      "enabled": true
    },
    {
      "route_id": "event.cleanup.apply",
      "event_kind": "cleanup.requested",
      "service_route_id": "service.cleanup.apply",
      "enabled": true
    }
  ],
  "test_scenario_policy": {
    "mode": "observer_configured",
    "decision": "",
    "allowed_decisions": [
      "none",
      "reuse_existing",
      "new_scenario_required"
    ],
    "reason": "",
    "required_evidence_ids": [
      "observer_test_strategy",
      "focused_tests"
    ],
    "timeline_event_type": "mf.test_scenario.decision",
    "timeline_event_kind": "scenario_spec",
    "e2e_decision": "",
    "allowed_e2e_decisions": [
      "e2e_current",
      "e2e_added",
      "e2e_deferred",
      "e2e_not_applicable"
    ],
    "followup_backlog_id": ""
  },
  "evidence_requirements": [
    {
      "id": "observer_test_strategy",
      "required": true,
      "phase": "plan",
      "kind": "test_strategy",
      "description": "Observer records the test-scenario decision, reason, required evidence ids, and E2E run/defer/not-applicable decision before delegation."
    },
    {
      "id": "implementation_evidence",
      "required": true,
      "phase": "implementation",
      "description": "Worker or observer records changed files, scope, and implementation notes."
    },
    {
      "id": "focused_tests",
      "required": true,
      "phase": "verification",
      "description": "Focused unit/API/typecheck evidence for each changed surface."
    },
    {
      "id": "integration_build",
      "required": false,
      "phase": "integration",
      "description": "Build or compile evidence when frontend/runtime assets are affected."
    },
    {
      "id": "integration_e2e",
      "required": false,
      "phase": "integration",
      "kind": "e2e",
      "description": "Observer sets required=true when the instantiated work affects UI/API/operator flows or any E2E-covered surface."
    },
    {
      "id": "contract_gate_tests",
      "required": false,
      "phase": "verification",
      "kind": "pytest",
      "description": "Focused tests for the instantiated contract gate behavior when the work changes contract validation or close-gate policy."
    },
    {
      "id": "docs_policy_update",
      "required": false,
      "phase": "implementation",
      "kind": "docs",
      "description": "Documentation update evidence when the work changes MF/subagent policy."
    },
    {
      "id": "e2e_deferred_followup",
      "required": false,
      "phase": "integration",
      "kind": "e2e_defer",
      "description": "Follow-up backlog evidence when observer explicitly defers E2E."
    }
  ],
  "timeline_contract": {
    "requirement_id_locations": [
      "payload.requirement_id",
      "payload.requirement_ids",
      "verification.requirement_id",
      "verification.requirement_ids",
      "verification.contract_evidence[].requirement_id"
    ],
    "trace_id_locations": [
      "payload.graph_trace_ids",
      "payload.graph_query_trace_ids",
      "verification.graph_trace_ids",
      "verification.graph_query_trace_ids",
      "verification.contract_evidence[].graph_trace_ids"
    ],
    "passing_statuses": [
      "accepted",
      "ok",
      "passed",
      "succeeded"
    ]
  },
  "gate_contract": {
    "close_requires": [
      "implementation",
      "verification",
      "close_ready",
      "all_required_evidence_requirements"
    ],
    "waiver_policy": "Required E2E can be disabled only in the instantiated contract with a reason and follow-up backlog for user-visible or API behavior."
  }
}

{
  "schema_version": "mf_workflow_runtime_contract.v1",
  "template_id": "mf_workflow_runtime.v1",
  "description": "Contract for deterministic MF workflow workers that call a unified local precheck/gate service for each privileged stage.",
  "contract_instance_id": "",
  "control_plane": {
    "observer_role": "monitoring_requirements_design_exception_handling",
    "worker_role": "deterministic_state_machine_executor",
    "precheck_service_role": "authoritative_gate_decision_and_evidence",
    "timeline_role": "append_only_audit_and_replay_source"
  },
  "route_prompt_contract": {
    "schema_version": "aming_route_prompt_contract.v1",
    "description": "Route-owned visible prompt context and pre-mutation action policy for observer, judger, and bounded implementation lanes.",
    "bundle_schema_version": "aming_route_prompt_alert_bundle.v1",
    "worker_prompt_contract_schema_version": "worker_prompt_contract.v1",
    "visible_injection_manifest_schema_version": "visible_injection_manifest.v1",
    "bundle_service_id": "route.prompt_alert_bundle",
    "action_gate_service_id": "route.action_precheck",
    "action_gate_function": "agent.governance.mf_subagent_contract.validate_route_action_gate",
    "dispatch_gate_function": "agent.governance.mf_subagent_contract.validate_mf_subagent_dispatch_gate",
    "required_hash_fields": [
      "route_context_hash",
      "prompt_contract_id",
      "prompt_contract_hash"
    ],
    "topology_fields": [
      "selected_topology",
      "recommended_topology",
      "required_lanes",
      "reason_codes",
      "observer_authorities"
    ],
    "worker_prompt_fields": [
      "target_files",
      "test_files",
      "acceptance_criteria",
      "route_identity",
      "evidence_required"
    ],
    "blocked_roles": [
      "observer",
      "judger"
    ],
    "blocked_implementation_actions": [
      "apply_patch",
      "edit_file",
      "edit_files",
      "write_file",
      "implementation_exec",
      "mutate_files",
      "run_implementation_command"
    ],
    "allowance": "bounded worker or subagent dispatch must carry matching route_context_hash, prompt_contract_id, and prompt_contract_hash; observer or judger direct mutation additionally requires an accepted matching waiver",
    "no_raw_context_policy": "route bundle output contains compact summaries, ids, refs, and hashes only; raw prompt, hidden context, observer-only context, and unmanifested injection text are excluded",
    "topology_policy": {
      "low_risk_topology": "lightweight_single_lane",
      "high_risk_topology": "observer_led_parallel_lanes",
      "p0_p1_governance_routing_runtime_requires_independent_verification": true,
      "observer_authorities": [
        "merge",
        "redeploy_governance",
        "graph_reconcile",
        "backlog_close",
        "waiver_approval",
        "merge_queue_mutation"
      ]
    }
  },
  "fixture_policy": {
    "decision": "new_scenario_required",
    "fixture_required": true,
    "fixture_path": "agent/tests/fixtures/mf_workflow_runtime.py",
    "scenario_ids": [
      "SCN-MF-WF-001",
      "SCN-MF-WF-002",
      "SCN-MF-WF-003",
      "SCN-MF-WF-004",
      "SCN-MF-WF-005",
      "SCN-MF-WF-006",
      "SCN-MF-WF-007",
      "SCN-MF-WF-008",
      "SCN-MF-WF-009",
      "SCN-MF-WF-010"
    ]
  },
  "stage_graph": [
    {
      "stage": "dispatch",
      "gate_kind": "mf_subagent.dispatch",
      "on_allow": "startup_gate",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "startup_gate",
      "gate_kind": "mf_subagent.startup",
      "on_allow": "implementation_wait",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "implementation_wait",
      "gate_kind": "",
      "on_worker_review_ready": "handoff_gate"
    },
    {
      "stage": "handoff_gate",
      "gate_kind": "mf_subagent.handoff",
      "on_allow": "merge_gate",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "merge_gate",
      "gate_kind": "workflow.merge",
      "on_allow": "merge_queue_entry",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "merge_queue_entry",
      "gate_kind": "workflow.merge_queue_entry",
      "on_allow": "merge_preview",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "merge_preview",
      "gate_kind": "workflow.merge_preview",
      "on_allow": "live_merge",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "live_merge",
      "gate_kind": "workflow.live_merge",
      "on_allow": "reconcile",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "reconcile",
      "gate_kind": "workflow.reconcile_policy",
      "on_allow": "close_gate",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    },
    {
      "stage": "close_gate",
      "gate_kind": "backlog.close",
      "on_allow": "done",
      "on_review_required": "observer_review",
      "on_block": "blocked"
    }
  ],
  "service_routes": [
    {
      "route_id": "service.route.prompt_alert_bundle",
      "service_id": "route.prompt_alert_bundle",
      "mode": "preview",
      "side_effect_class": "read",
      "requirement_ids": [
        "route_context_hash",
        "prompt_contract_hash",
        "visible_injection_manifest"
      ],
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "payload.route_id",
          "payload.prompt_contract_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.route.action_precheck",
      "service_id": "route.action_precheck",
      "mode": "gate",
      "side_effect_class": "gate",
      "requirement_ids": [
        "route_context_hash",
        "prompt_contract_id",
        "prompt_contract_hash",
        "route_action_allowed"
      ],
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "payload.route_context_hash",
          "payload.prompt_contract_id",
          "payload.prompt_contract_hash",
          "payload.action",
          "payload.caller_role",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.precheck.run",
      "service_id": "precheck.run",
      "mode": "gate",
      "side_effect_class": "gate",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.gate.close",
      "service_id": "gate.close",
      "mode": "gate",
      "side_effect_class": "gate",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.cleanup.preview",
      "service_id": "cleanup.preview",
      "mode": "preview",
      "side_effect_class": "read",
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    },
    {
      "route_id": "service.cleanup.apply",
      "service_id": "cleanup.apply",
      "mode": "apply",
      "side_effect_class": "write",
      "required_permissions": [
        "cleanup.apply"
      ],
      "idempotency_key_policy": {
        "fields": [
          "event_id",
          "event_kind",
          "stage",
          "task_id",
          "backlog_id",
          "route_id",
          "service_id"
        ]
      }
    }
  ],
  "event_routes": [
    {
      "route_id": "event.route_prompt_context.preview",
      "event_kind": "route.prompt_context.requested",
      "stages": [
        "dispatch",
        "startup_gate",
        "implementation_wait",
        "handoff_gate"
      ],
      "service_route_id": "service.route.prompt_alert_bundle",
      "required_evidence_ids": [
        "route_context_hash",
        "prompt_contract_hash",
        "visible_injection_manifest"
      ],
      "enabled": true
    },
    {
      "route_id": "event.route_action.pre_mutation",
      "event_kind": "route.action.requested",
      "stages": [
        "dispatch",
        "startup_gate",
        "implementation_wait",
        "handoff_gate"
      ],
      "service_route_id": "service.route.action_precheck",
      "required_evidence_ids": [
        "route_context_hash",
        "prompt_contract_id",
        "prompt_contract_hash",
        "route_action_allowed"
      ],
      "enabled": true
    },
    {
      "route_id": "event.stage_completed.precheck",
      "event_kind": "stage.completed",
      "service_route_id": "service.precheck.run",
      "enabled": true
    },
    {
      "route_id": "event.backlog_close.gate",
      "event_kind": "backlog.close.requested",
      "stage": "close_gate",
      "service_route_id": "service.gate.close",
      "enabled": true
    },
    {
      "route_id": "event.cleanup.preview",
      "event_kind": "cleanup.requested",
      "service_route_id": "service.cleanup.preview",
      "enabled": true
    },
    {
      "route_id": "event.cleanup.apply",
      "event_kind": "cleanup.requested",
      "service_route_id": "service.cleanup.apply",
      "enabled": true
    }
  ],
  "stage_io": {
    "dispatch": {
      "inputs": [
        "contract",
        "worker_worktree",
        "target_worktree",
        "branch_ref",
        "merge_queue_id",
        "base_commit",
        "target_head_commit",
        "graph_snapshot_commit",
        "fence_token",
        "owned_files",
        "forbidden_paths"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "worker_git",
        "target_git",
        "branch_ref",
        "worktree_path",
        "merge_queue_id",
        "current_target_head",
        "graph_current",
        "next_stage"
      ]
    },
    "implementation_wait": {
      "inputs": [
        "worker_status",
        "review_ready_signal"
      ],
      "outputs": [
        "decision",
        "next_stage"
      ]
    },
    "startup_gate": {
      "inputs": [
        "contract",
        "worker_worktree",
        "target_worktree",
        "actual_git_root",
        "actual_cwd",
        "branch_ref",
        "base_commit",
        "target_head_commit",
        "fence_token",
        "actual_fence_token",
        "owned_files"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "expected_worker_git",
        "actual_runtime_git",
        "target_git",
        "same_as_expected_worker",
        "same_as_target_main",
        "target_dirty_owned_files",
        "next_stage"
      ]
    },
    "handoff_gate": {
      "inputs": [
        "contract",
        "worker_worktree",
        "fence_token",
        "owned_files",
        "forbidden_paths",
        "tests_evidence",
        "timeline_evidence"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "dirty_scope_exact_match",
        "worker_git",
        "next_stage"
      ]
    },
    "merge_gate": {
      "inputs": [
        "contract",
        "main_worktree",
        "source_worktree",
        "source_commit",
        "merge_queue_id",
        "branch_ref",
        "fence_token",
        "precheck_token",
        "contract_evidence",
        "timeline_evidence"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "observed_source_head",
        "source_commit",
        "main_git",
        "source_git",
        "next_stage"
      ]
    },
    "merge_queue_entry": {
      "inputs": [
        "contract",
        "main_worktree",
        "source_worktree",
        "source_commit",
        "target_head_commit",
        "merge_queue_id",
        "branch_ref",
        "fence_token",
        "precheck_token",
        "timeline_evidence"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "merge_queue_id",
        "branch_ref",
        "observed_target_head",
        "source_commit",
        "next_stage"
      ]
    },
    "merge_preview": {
      "inputs": [
        "contract",
        "main_worktree",
        "source_worktree",
        "source_commit",
        "target_head_commit",
        "merge_queue_id",
        "merge_preview_id",
        "fence_token",
        "precheck_token",
        "merge_preview_evidence"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "merge_preview_id",
        "observed_target_head",
        "merge_preview_evidence_present",
        "next_stage"
      ]
    },
    "live_merge": {
      "inputs": [
        "contract",
        "main_worktree",
        "source_worktree",
        "source_commit",
        "merge_commit",
        "target_head_before_merge",
        "target_head_after_merge",
        "merge_queue_id",
        "fence_token",
        "precheck_token"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "merge_commit",
        "target_head_after_merge",
        "observed_target_head",
        "next_stage"
      ]
    },
    "reconcile": {
      "inputs": [
        "contract",
        "source_commit",
        "merge_commit",
        "fence_token",
        "precheck_token",
        "changed_files",
        "scope_kind",
        "e2e_decision",
        "graph_rule_changed"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "changed_files",
        "scope_kind",
        "next_stage"
      ]
    },
    "close_gate": {
      "inputs": [
        "contract",
        "merge_commit",
        "fence_token",
        "precheck_token",
        "contract_evidence",
        "timeline_evidence",
        "required_evidence_ids"
      ],
      "outputs": [
        "precheck_run_id",
        "decision",
        "close_ready_present",
        "mf_timeline_precheck_compatible",
        "next_stage"
      ]
    }
  },
  "gate_registry": {
    "route.action.pre_mutation": [
      "route_context_hash_present",
      "prompt_contract_id_present",
      "prompt_contract_hash_present",
      "route_alerts_acknowledged",
      "observer_judger_implementation_action_blocked",
      "bounded_dispatch_evidence_matches_route",
      "accepted_waiver_matches_route_when_required"
    ],
    "mf_subagent.dispatch": [
      "target_main_worktree_clean",
      "worker_worktree_clean",
      "isolated_worktree",
      "worker_head_matches_base_commit",
      "target_head_matches_target_head_commit",
      "branch_ref_present",
      "merge_queue_id_present",
      "active_graph_current_at_dispatch",
      "write_scope_present",
      "contract_shape_valid"
    ],
    "mf_subagent.startup": [
      "actual_runtime_git_root_reported",
      "actual_runtime_matches_expected_worker_worktree",
      "actual_runtime_not_target_main_worktree",
      "worker_and_actual_heads_match_base_commit",
      "worker_and_actual_branches_match_branch_ref",
      "target_head_matches_target_head_commit",
      "target_main_worktree_clean",
      "target_dirty_owned_file_overlap_absent",
      "fence_token_reported_and_matches",
      "write_scope_present",
      "contract_shape_valid"
    ],
    "mf_subagent.handoff": [
      "dirty_scope_exact_match",
      "untracked_and_ignored_files_counted",
      "forbidden_paths_absent",
      "tests_evidence_present",
      "timeline_evidence_present"
    ],
    "workflow.merge": [
      "main_worktree_clean",
      "source_candidate_committed",
      "subject_commit_matches_precheck_token",
      "contract_evidence_complete",
      "implementation_and_verification_timeline_present",
      "independent_verification_lane_evidence_for_p0_p1_governance_routing_runtime"
    ],
    "workflow.merge_queue_entry": [
      "merge_queue_id_present",
      "branch_ref_present",
      "target_head_still_current",
      "source_candidate_committed",
      "subject_commit_matches_precheck_token",
      "implementation_and_verification_timeline_present"
    ],
    "workflow.merge_preview": [
      "merge_queue_id_present",
      "merge_preview_id_present",
      "target_head_still_current",
      "source_candidate_committed",
      "subject_commit_matches_precheck_token",
      "merge_preview_evidence_present"
    ],
    "workflow.live_merge": [
      "merge_queue_id_present",
      "source_candidate_committed",
      "merge_commit_recorded",
      "target_head_after_merge_matches_merge_commit",
      "subject_commit_matches_precheck_token"
    ],
    "workflow.reconcile_policy": [
      "docs_or_code_module_scope_reconcile_allowed",
      "graph_rule_change_requires_full_reconcile",
      "runtime_or_dashboard_change_requires_e2e_or_review",
      "subject_commit_matches_precheck_token"
    ],
    "backlog.close": [
      "mf_timeline_precheck_passed",
      "close_ready_present",
      "merge_commit_recorded",
      "required_evidence_ids_present",
      "subject_commit_matches_precheck_token",
      "independent_verification_lane_evidence_for_p0_p1_governance_routing_runtime"
    ]
  },
  "lane_policy": {
    "green": "all gates pass with deterministic evidence and no runtime/API/dashboard change",
    "yellow": "warnings, env fallback, waiver request, stale token, nonblocking preflight uncertainty, graph-rule/fingerprint change, or runtime/API/dashboard review with E2E -> observer_review",
    "red": "dirty main, same-worktree dispatch, missing evidence, unknown gate, forbidden paths, conflict, runtime/API/dashboard change without E2E, invalid contract, or token mismatch -> blocked"
  },
  "precheck_result_contract": {
    "required_fields": [
      "precheck_run_id",
      "kind",
      "contract_id",
      "stage",
      "decision",
      "status",
      "subject",
      "evidence",
      "evidence_hash",
      "created_at"
    ],
    "allowed_decisions": [
      "allow",
      "review_required",
      "block"
    ],
    "token_policy": "merge, merge_queue_entry, merge_preview, live_merge, reconcile, and close must reference a precheck_run_id whose subject commit/path evidence still matches current state"
  },
  "observer_escalation": {
    "review_stages": [
      "observer_review"
    ],
    "blocked_stages": [
      "blocked"
    ],
    "review_required_reasons": [
      "warnings",
      "waiver_request",
      "graph_rule_change",
      "runtime_or_dashboard_change_with_e2e",
      "nonblocking_preflight_uncertainty"
    ],
    "blocked_reasons": [
      "dirty_main",
      "dirty_worker_outside_scope",
      "same_worktree_dispatch",
      "missing_required_evidence",
      "unknown_gate",
      "invalid_contract",
      "forbidden_path",
      "token_mismatch",
      "runtime_or_dashboard_change_without_e2e"
    ]
  },
  "evidence_requirements": [
    {
      "id": "route_prompt_bundle",
      "required": true,
      "phase": "dispatch",
      "kind": "service_route"
    },
    {
      "id": "route_action_gate",
      "required": true,
      "phase": "pre_mutation",
      "kind": "local_precheck"
    },
    {
      "id": "independent_verification_lane",
      "required": false,
      "phase": "verification",
      "kind": "qa",
      "description": "Required by merge and close prechecks when the route classifies P0/P1 governance, routing, permission, or runtime changes as observer-led parallel lanes."
    },
    {
      "id": "fixture_contract",
      "required": true,
      "phase": "implementation",
      "kind": "test_fixture"
    },
    {
      "id": "precheck_service_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "workflow_worker_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "merge_close_gate_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "merge_queue_gate_tests",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "compact_precheck_evidence",
      "required": true,
      "phase": "verification",
      "kind": "pytest"
    },
    {
      "id": "docs_policy_update",
      "required": true,
      "phase": "implementation",
      "kind": "docs"
    },
    {
      "id": "e2e_not_applicable",
      "required": true,
      "phase": "verification",
      "kind": "e2e"
    }
  ]
}

{
  "schema_version": 1,
  "scenarios": [
    {
      "id": "simple_user_entry",
      "title": "Simple user entry and Project Inbox flow",
      "description": "Focused validation for ordinary user entry, Simple Mode, Project Inbox, and observer command queue controls.",
      "target_project": "aming-claw",
      "target_ref": "HEAD",
      "runner": "commands",
      "dependencies": [
        {
          "id": "python",
          "kind": "command",
          "command": "{python}",
          "required": true,
          "remediation": "Install Python or set PYTHON/PYTHON_BIN to the interpreter used for this checkout."
        },
        {
          "id": "node",
          "kind": "command",
          "command": "{node}",
          "required": true,
          "remediation": "Install Node.js so the focused dashboard E2E contract can run."
        }
      ],
      "commands": [
        {
          "id": "simple_mode_project_inbox_flow",
          "cwd": "repo",
          "command": [
            "{python}",
            "-m",
            "pytest",
            "agent/tests/test_raw_requirement.py::test_simple_mode_observer_command_flow_for_execution_and_worker_controls"
          ],
          "env": {
            "PYTEST_DISABLE_PLUGIN_AUTOLOAD": "1"
          },
          "timeout_ms": 120000
        },
        {
          "id": "simple_mode_request_first_desktop_contract",
          "cwd": "repo",
          "command": [
            "{node}",
            "frontend/dashboard/scripts/e2e-projects.mjs",
            "--only",
            "simple-mode-request-first-desktop"
          ],
          "env": {},
          "timeout_ms": 120000
        },
        {
          "id": "ordinary_user_entry_desktop_contract",
          "cwd": "repo",
          "command": [
            "{node}",
            "frontend/dashboard/scripts/e2e-projects.mjs",
            "--only",
            "ordinary-user-entry-desktop"
          ],
          "env": {},
          "timeout_ms": 120000
        },
        {
          "id": "simple_first_entry_engineer_escape_desktop_contract",
          "cwd": "repo",
          "command": [
            "{node}",
            "frontend/dashboard/scripts/e2e-projects.mjs",
            "--only",
            "simple-first-entry-engineer-escape-desktop"
          ],
          "env": {},
          "timeout_ms": 120000
        },
        {
          "id": "observer_session_command_queue",
          "cwd": "repo",
          "command": [
            "{python}",
            "-m",
            "pytest",
            "agent/tests/test_observer_session.py",
            "agent/tests/test_observer_command_queue.py"
          ],
          "env": {
            "PYTEST_DISABLE_PLUGIN_AUTOLOAD": "1"
          },
          "timeout_ms": 120000
        }
      ],
      "artifacts": [
        {
          "id": "simple_mode_request_first_desktop_contract",
          "kind": "e2e_contract",
          "path": "frontend/dashboard/scripts/e2e-projects.mjs",
          "description": "Desktop-only request-first Simple Mode check: request cards must render before helper status, counters, and tabs, and default visible copy must avoid operator terms."
        },
        {
          "id": "ordinary_user_entry_desktop_contract",
          "kind": "e2e_contract",
          "path": "frontend/dashboard/scripts/e2e-projects.mjs",
          "description": "Desktop-only ordinary-user entry check: /dashboard defaults to Simple Mode, Simple Mode exposes a secondary engineer-panel action, Projects keeps a request entry after escalation, and entry copy avoids operator terms."
        },
        {
          "id": "simple_first_entry_engineer_escape_desktop_contract",
          "kind": "e2e_contract",
          "path": "frontend/dashboard/scripts/e2e-projects.mjs",
          "description": "Regression check for the simple-first route: ordinary users land in Simple Mode before entering the engineer panel."
        }
      ]
    },
    {
      "id": "paradigm_route_context_demo",
      "title": "Paradigm route context and test-flow proof",

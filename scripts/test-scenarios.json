          "id": "paradigm-external-route-manifest",
          "kind": "generated_external_manifest",
          "deterministic": true,
          "calls_models": false,
          "description": "The demo creates a temporary external project route manifest and verifies source-controlled registration metadata."
        }
      ],
      "evidence_requirements": [
        {
          "id": "fixture_only_route_runs",
          "kind": "demo_output",
          "field": "proof_cases.fixture_only_route_runs.status",
          "expected": "passed"
        },
        {
          "id": "docker_route_blocks_without_approval",
          "kind": "demo_output",
          "field": "proof_cases.docker_route_blocks_without_approval.status",
          "expected": "blocked"
        },
        {
          "id": "live_ai_route_blocks_without_approval",
          "kind": "demo_output",
          "field": "proof_cases.live_ai_route_blocks_without_approval.status",
          "expected": "blocked"
        },
        {
          "id": "external_project_registers_fixture_route",
          "kind": "demo_output",
          "field": "proof_cases.external_project_registers_fixture_route.status",
          "expected": "passed"
        },
        {
          "id": "route_prompt_bundle_is_hashable_and_low_noise",
          "kind": "demo_output",
          "field": "proof_cases.route_prompt_bundle_is_hashable_and_low_noise.raw_context_exposed",
          "expected": false
        }
      ],
      "commands": [
        {
          "id": "paradigm_route_context_demo",
          "cwd": "repo",
          "command": [
            "{python}",
            "scripts/paradigm-route-context-demo.py",
            "--json"
          ],
          "env": {
            "PYTEST_DISABLE_PLUGIN_AUTOLOAD": "1"
          },
          "timeout_ms": 120000
        }
      ],
      "artifacts": [
        {
          "id": "paradigm_route_context_demo_script",
          "kind": "demo_script",
          "path": "scripts/paradigm-route-context-demo.py",
          "description": "Runnable JSON proof tying the article's paradigm surfaces to route context and test-flow route evidence."
        }
      ]
    },
    {
      "id": "service_router_docker_fixture",
      "title": "Service router Docker fixture lane",

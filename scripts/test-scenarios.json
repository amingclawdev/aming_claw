            "--format",
            "{{json .ServerVersion}}"
          ],
          "env": {},
          "timeout_ms": 30000
        },
        {
          "id": "mock_ai_docker_no_credential_structured_output",
          "cwd": "repo",
          "command": [
            "sh",
            "-lc",
            "image=\"${AMING_CLAW_MOCK_AI_DOCKER_IMAGE:-aming-claw-install-audit-codex:latest}\"; docker run --rm --network none --pull=never --env OPENAI_API_KEY= --env ANTHROPIC_API_KEY= --env AMING_CLAW_LIVE_AI=0 --env AMING_CLAW_MODEL_CALLS=mocked --env AMING_CLAW_DOCKER_IMAGE=\"$image\" --entrypoint node \"$image\" -e 'const assert = require(\"node:assert/strict\"); const envelope = {schema_version: 1, source: \"mock_ai_docker_fixture\", runtime: \"docker\", image: process.env.AMING_CLAW_DOCKER_IMAGE, network: \"none\", calls_models: false, payload: {observer_alert_acknowledged: true, recommendation: \"qa_pass\"}}; assert.equal(process.env.OPENAI_API_KEY || \"\", \"\"); assert.equal(process.env.ANTHROPIC_API_KEY || \"\", \"\"); assert.equal(process.env.AMING_CLAW_LIVE_AI, \"0\"); assert.equal(process.env.AMING_CLAW_MODEL_CALLS, \"mocked\"); assert.equal(envelope.calls_models, false); console.log(JSON.stringify(envelope));'"
          ],
          "env": {
            "OPENAI_API_KEY": "",
            "ANTHROPIC_API_KEY": "",
            "AMING_CLAW_LIVE_AI": "0",
            "AMING_CLAW_MODEL_CALLS": "mocked"
          },
          "timeout_ms": 30000
        }
      ],

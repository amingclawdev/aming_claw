        "test_files": [
          "agent/tests/test_paradigm_route_context_demo.py",
          "agent/tests/test_test_scenario_manager.py",
          "agent/tests/test_service_router.py"
        ]
      },
      "route_context": {
        "service_id": "paradigm.route_context_demo",
        "event_kind": "paradigm.demo.requested",
        "mode": "preview",
        "side_effect_class": "read"
      },
      "test_flow_route": {
        "source": "scenario_registry",
        "decision": "mixed",
        "primary_lane": "fixture_only",
        "lanes": [
          "focused_unit",
          "fixture_only"
        ],
        "evidence_ids": [
          "fixture_only_route_runs",
          "docker_route_blocks_without_approval",
          "live_ai_route_blocks_without_approval",
          "external_project_registers_fixture_route",
          "route_prompt_bundle_is_hashable_and_low_noise"

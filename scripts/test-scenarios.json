          "required": true,
          "remediation": "Install Python or set PYTHON/PYTHON_BIN to the interpreter used for this checkout."
        },
        {
          "id": "node",
          "kind": "command",
          "command": "{node}",
          "required": true,
          "remediation": "Install Node.js so the test scenario manager proof cases can run."
        }
      ],
      "execution_policy": {
        "lane": "fixture_only",
        "autorun": true,
        "requires_flags": [],
        "live_ai": "disabled",
        "model_calls": "forbidden"
